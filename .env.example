APP_NAME="Monitoring Bed ICU"
APP_ENV=production
APP_KEY=                          
APP_DEBUG=false
APP_URL=http://192.168.200.142    ← ganti dengan IP server aplikasi
APP_TIMEZONE=Asia/Jakarta

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# ── Database Aplikasi ICU (SQL Server — read+write) ───────────────────────────
DB_CONNECTION=sqlsrv
DB_HOST=192.168.200.160
DB_PORT=1433
DB_DATABASE=mapping_bed_icu
DB_USERNAME=icu_app
DB_PASSWORD=                      ← isi password dari DBA
DB_TRUST_CERT=true
DB_ENCRYPT=false

# ── Database RS (SQL Server — read only) ──────────────────────────────────────
DB_RSUS_ENABLED=true
DB_RSUS_HOST=192.168.200.160
DB_RSUS_PORT=1433
DB_RSUS_DATABASE=DB_RSUS
DB_RSUS_USERNAME=icu_app
DB_RSUS_PASSWORD=                 ← sama dengan DB_PASSWORD di atas
DB_RSUS_TRUST_CERT=true

# ── Session & Cache ──────────────────────────────────────────────────────────
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
DB_CACHE_TABLE=IB_cache
DB_CACHE_LOCK_TABLE=IB_cache_locks

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

QUEUE_CONNECTION=sync

# ── Keycloak SSO ──────────────────────────────────────────────────────────────
KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=http://192.168.200.157:8081
KEYCLOAK_REALM=myrealm
KEYCLOAK_CLIENT_ID=icu-bed
KEYCLOAK_CLIENT_SECRET=           ← isi dari Keycloak Admin Console
KEYCLOAK_REDIRECT_URI=http://192.168.200.142/auth/keycloak/callback

VITE_APP_NAME="${APP_NAME}"
