APP_NAME="Monitoring Bed ICU"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# debug hanya untuk dev, gunakan error di prod
LOG_LEVEL=error

# ── Database — SQL Server RS (1 database untuk semua) ─────────────────────────
# Koneksi utama aplikasi (tabel IB_* dan tabel RS ada di DB yang sama)
DB_CONNECTION=sqlsrv
DB_HOST=192.168.200.160
DB_PORT=1433
DB_DATABASE=DB_RSUS
DB_USERNAME=icu_app
DB_PASSWORD=
DB_TRUST_CERT=true
DB_ENCRYPT=false

# Koneksi RSUS — isi sama dengan di atas kalau 1 database
# Kosongkan kalau ingin otomatis inherit dari DB_* di atas
DB_RSUS_HOST=192.168.200.160
DB_RSUS_PORT=1433
DB_RSUS_DATABASE=DB_RSUS
DB_RSUS_USERNAME=icu_app
DB_RSUS_PASSWORD=
DB_RSUS_TRUST_CERT=true

# ── Session ────────────────────────────────────────────────────────────────────
# Gunakan file — tidak butuh tabel database
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ── Cache ──────────────────────────────────────────────────────────────────────
CACHE_STORE=database
DB_CACHE_TABLE=IB_cache
DB_CACHE_LOCK_TABLE=IB_cache_locks

# ── Queue ──────────────────────────────────────────────────────────────────────
# Aplikasi ini tidak pakai background job — gunakan sync
QUEUE_CONNECTION=sync

# ── Lainnya ────────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# ── Keycloak SSO ──────────────────────────────────────────────────────────────
# true  = paksa aktif (prod)
# false = nonaktif (dev tanpa SSO)
# auto  = cek koneksi TCP otomatis
KEYCLOAK_ENABLED=true

# URL Keycloak server (tanpa trailing slash)
KEYCLOAK_BASE_URL=http://192.168.200.157:8081
KEYCLOAK_REALM=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=https://your-domain.com/auth/keycloak/callback

VITE_APP_NAME="${APP_NAME}"
