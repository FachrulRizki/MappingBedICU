APP_NAME="Mapping Bed ICU"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://your-server-ip

APP_LOCALE=id
APP_FALLBACK_LOCALE=id
APP_FAKER_LOCALE=id_ID

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ── Database Utama Aplikasi ───────────────────────────────────────────────────
#
# [SKEMA A — Prod tanpa MySQL, pakai SQL Server RS]
# Buat database baru "mapping_bed_icu" di SQL Server RS terlebih dahulu.
#
DB_CONNECTION=sqlsrv
DB_HOST=192.168.200.160
DB_PORT=1433
DB_DATABASE=mapping_bed_icu
DB_USERNAME=icu_app
DB_PASSWORD=
DB_TRUST_CERT=true
DB_ENCRYPT=false
#
# [SKEMA B — Prod dengan MySQL]
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=mapping_bed_icu
# DB_USERNAME=icu_user
# DB_PASSWORD=
#
# [SKEMA C — Dev lokal (MAMP/XAMPP)]
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=8889
# DB_DATABASE=icu-urip
# DB_USERNAME=root
# DB_PASSWORD=root

# ── Database RS (SQL Server — read only) ──────────────────────────────────────
# DB_RSUS_ENABLED=true   → paksa aktif — pakai SQL Server RS live (PROD)
# DB_RSUS_ENABLED=false  → paksa nonaktif — pakai DB lokal + data dummy (DEV)
# DB_RSUS_ENABLED=auto   → cek koneksi TCP otomatis tiap 30 detik (default)
DB_RSUS_ENABLED=true
DB_RSUS_HOST=192.168.200.160
DB_RSUS_PORT=1433
DB_RSUS_DATABASE=DB_RSUS
DB_RSUS_USERNAME=
DB_RSUS_PASSWORD=
DB_RSUS_TRUST_CERT=true

# ── Session & Cache ───────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# ── Keycloak SSO ──────────────────────────────────────────────────────────────
# KEYCLOAK_ENABLED=true   → paksa aktif
# KEYCLOAK_ENABLED=false  → nonaktifkan (dev lokal)
# KEYCLOAK_ENABLED=auto   → cek koneksi otomatis (default)
KEYCLOAK_ENABLED=true
KEYCLOAK_BASE_URL=http://192.168.200.157:8081
KEYCLOAK_REALM=myrealm
KEYCLOAK_CLIENT_ID=icu-bed
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REDIRECT_URI=http://your-server-ip/auth/keycloak/callback

# ── Mail (opsional) ───────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@rs.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
